# .gitignore generado — entradas comunes para proyectos Node/JS, IDEs y SO

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-lock.yaml

# Environment files
.env
.env.*

# Build output
/dist/
/build/
/out/
/.parcel-cache/
.next/
.nuxt/

# Test coverage
/coverage/
.nyc_output/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Misc caches
.cache/
.temp/
.pnp/
.pnp.js
*.tgz

# Docker
docker-compose.override.yml

# Optional: lockfiles often tracked — uncomment if you prefer ignorarlos
## package-lock.json
## yarn.lock

# Coverage and test runners
/.nyc_output/
/.cache/
/jest-cache/

# Service/runtime
*.pid
*.seed
*.pid.lock

# Python artifacts (if present)
__pycache__/
*.py[cod]
*$py.class

# Terraform
.terraform/
.terraform.lock.hcl

# VS Code history extension
.history/

# End of .gitignore
